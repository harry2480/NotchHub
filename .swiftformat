# SwiftFormat configuration for NotchHub (スタイルガイド.md §1)
--swiftversion 5.10
--indent 4
--maxwidth 120
--self remove
--commas inline
--trailingcommas always
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
# Keep `{` attached to a multi-line condition's last line to match SwiftLint's
# opening_brace rule (the two tools otherwise disagree).
--disable wrapMultilineStatementBraces
--exclude .build,apps,Tests/NotchHubTests/.build
