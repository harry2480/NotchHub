generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Joke {
  id        String   @id @default(cuid())
  theme     String
  content   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("jokes")
}
