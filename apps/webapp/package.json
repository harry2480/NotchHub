{
	"name": "webapp",
	"private": true,
	"type": "module",
	"prisma": {
		"seed": "npx tsx prisma/seed.ts"
	},
	"scripts": {
		"dev": "next dev",
		"build": "prisma generate && next build",
		"build:vercel": "prisma migrate deploy && prisma generate && next build",
		"start": "next start",
		"typecheck": "tsc --noEmit",
		"test:unit": "vitest run --dir test/unit",
		"test:integration": "INTEGRATION_TEST=true vitest run --dir test/integration",
		"depcruise": "depcruise src --config .dependency-cruiser.cjs",
		"prisma": "prisma"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^3.0.58",
		"@prisma/client": "^6",
		"ai": "^6.0.116",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2",
		"lucide-react": "^0.474",
		"next": "^15",
		"radix-ui": "^1.4.3",
		"react": "^19",
		"react-dom": "^19",
		"tailwind-merge": "^3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitest/coverage-v8": "^3.2.4",
		"dependency-cruiser": "^16",
		"dotenv": "^17.3.1",
		"prisma": "^6",
		"tailwindcss": "^4",
		"tsx": "^4",
		"typescript": "^5.7",
		"vitest": "^3"
	}
}
